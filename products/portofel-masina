<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Portofel Classic - Zalmoxis</title>

<style>
body{
margin:0;
font-family:-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto;
background:#f3e7db;
color:#2a1c16;
}

.container{
max-width:1100px;
margin:100px auto;
display:grid;
grid-template-columns:1fr 1fr;
gap:40px;
padding:20px;
}

/* IMAGE */
.image-box img{
width:100%;
border-radius:16px;
box-shadow:0 10px 30px rgba(0,0,0,0.15);
}

/* INFO */
h1{
font-size:34px;
margin-bottom:10px;
}

.price{
font-size:22px;
margin:10px 0;
font-weight:600;
}

.desc{
color:#5a3a2e;
line-height:1.5;
}

/* COLORS */
.colors{
margin-top:20px;
}

.color-btn{
display:inline-block;
padding:8px 14px;
border:1px solid #2a1c16;
border-radius:8px;
cursor:pointer;
margin-right:10px;
transition:0.3s;
}

.color-btn:hover{
background:#2a1c16;
color:#fff;
}

/* BUTTON */
.btn{
display:inline-block;
margin-top:25px;
padding:12px 18px;
background:#2a1c16;
color:#fff;
text-decoration:none;
border-radius:10px;
transition:0.3s;
}

.btn:hover{
background:#c49a6c;
color:#2a1c16;
}

/* MOBILE */
@media(max-width:768px){
.container{
grid-template-columns:1fr;
}
}
</style>
</head>

<body>

<div class="container">

<!-- IMAGE -->
<div class="image-box">
<img id="productImg" src="https://images.unsplash.com/photo-1600180758890?auto=format&fit=crop&w=800&q=80">
</div>

<!-- INFO -->
<div>
<h1>Portofel Classic</h1>

<div class="price">349 MDL</div>

<div class="desc">
Portofel realizat manual din piele naturală full-grain.
Cusut manual pentru durabilitate maximă și design minimalist.
</div>

<!-- COLORS -->
<div class="colors">
<h3>Culori</h3>

<span class="color-btn" onclick="changeColor('black')">Negru</span>
<span class="color-btn" onclick="changeColor('brown')">Maro</span>
<span class="color-btn" onclick="changeColor('cognac')">Coniac</span>
</div>

<!-- BUTTON -->
<a class="btn" href="https://instagram.com/zalmoxis_leather" target="_blank">
Comandă pe Instagram
</a>

</div>

</div>

<script>
function changeColor(color){

let img = document.getElementById("productImg");

if(color === "black"){
img.src = "https://images.unsplash.com/photo-1600180758890?auto=format&fit=crop&w=800&q=80";
}

if(color === "brown"){
img.src = "https://images.unsplash.com/photo-1618354691792-d1d42acfd860?auto=format&fit=crop&w=800&q=80";
}

if(color === "cognac"){
img.src = "https://images.unsplash.com/photo-1600180758890?auto=format&fit=crop&w=800&q=80";
}
}
</script>

</body>
</html>
